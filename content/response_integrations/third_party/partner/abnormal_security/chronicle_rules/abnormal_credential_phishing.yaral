rule abnormal_security_credential_phishing {

  meta:
    author = "Abnormal Security"
    description = "Targeted detection for credential phishing, BEC, account takeover, and invoice fraud variants identified by Abnormal. These attack types historically have the highest analyst-action rate, so they warrant their own rule for routing/playbook selection."
    severity = "HIGH"
    priority = "HIGH"
    type = "alert"
    data_source = "Abnormal Security"
    platform = "Email"
    mitre_attack_tactic = "Initial Access"
    mitre_attack_technique = "T1566.002"
    yara_version = "YL2.0"
    rule_version = "1.1"

  events:
    $e.metadata.vendor_name = "ABNORMAL_SECURITY"
    $e.metadata.log_type = "ABNORMAL_SECURITY"
    $e.additional.fields["sourcetype"] = "threat_log"
    (
      re.regex($e.extracted.fields["event.abx_body.attack_type"], `(?i)credential.*phishing|phishing.*credential`) or
      re.regex($e.extracted.fields["event.abx_body.attack_type"], `(?i)business.*email.*compromise|^bec$`) or
      re.regex($e.extracted.fields["event.abx_body.attack_type"], `(?i)account.*takeover|invoice.*fraud`)
    )

  outcome:
    $threat_id = array_distinct($e.extracted.fields["event.abx_body.threat_id"])
    $attack_type = array_distinct($e.extracted.fields["event.abx_body.attack_type"])
    $attack_strategy = array_distinct($e.extracted.fields["event.abx_body.attack_strategy"])
    $sender = array_distinct($e.extracted.fields["event.abx_body.from_address"])
    $recipient = array_distinct($e.extracted.fields["event.abx_body.recipient_address"])
    $subject = array_distinct($e.extracted.fields["event.abx_body.subject"])
    $attack_score = array_distinct($e.extracted.fields["event.abx_body.attack_score"])

  condition:
    $e
}
